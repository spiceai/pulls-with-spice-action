{
    "name": "pulls-with-spice-action",
    "version": "2.0.0",
    "description": "GitHub Action to enforce standards for pull requests with extra spice",
    "main": "dist/index.js",
    "scripts": {
        "build": "ncc build src/index.ts --license LICENSE -o dist",
        "format": "prettier --write **/*.ts",
        "format-check": "prettier --check **/*.ts",
        "lint": "eslint src/**/*.ts",
        "test": "jest",
        "all": "npm run format && npm run lint && npm run build"
    },
    "keywords": [
        "github",
        "actions",
        "pull-requests",
        "quality",
        "auto-labeling"
    ],
    "author": "Luke Kim (Spice AI)",
    "license": "Apache-2.0",
    "dependencies": {
        "@actions/core": "^2.0.2",
        "@actions/github": "^9.0.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^22",
        "@typescript-eslint/eslint-plugin": "^8.19.1",
        "@typescript-eslint/parser": "^8.19.1",
        "@vercel/ncc": "^0.38.3",
        "eslint": "^8.57.1",
        "jest": "^29.7.0",
        "prettier": "^3.4.2",
        "ts-jest": "^29.2.5",
        "typescript": "^5.7.3"
    }
}