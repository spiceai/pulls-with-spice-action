{
    "name": "pulls-with-spice-action",
    "version": "1.0.2",
    "description": "GitHub Action to enforce quality standards for pull requests with extra spice",
    "main": "dist/index.js",
    "scripts": {
        "build": "ncc build src/index.ts --license LICENSE -o dist",
        "format": "prettier --write **/*.ts",
        "format-check": "prettier --check **/*.ts",
        "lint": "eslint src/**/*.ts",
        "test": "jest",
        "all": "npm run format && npm run lint && npm run build"
    },
    "keywords": [
        "github",
        "actions",
        "pull-requests",
        "quality"
    ],
    "author": "Luke Kim (Spice AI)",
    "license": "Apache-2.0",
    "dependencies": {
        "@actions/core": "^1.10.1",
        "@actions/github": "^6.0.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.6",
        "@types/node": "^20.8.9",
        "@typescript-eslint/eslint-plugin": "^6.9.0",
        "@typescript-eslint/parser": "^6.9.0",
        "@vercel/ncc": "^0.38.3",
        "eslint": "^8.53.0",
        "jest": "^29.7.0",
        "prettier": "^3.0.3",
        "ts-jest": "^29.1.1",
        "typescript": "^5.2.2"
    }
}